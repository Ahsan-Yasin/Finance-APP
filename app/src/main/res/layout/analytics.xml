<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".AnalyticsActivity">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#F4F5F9"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#4A4A4A" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analytics"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/btn_back"
            app:layout_constraintEnd_toStartOf="@+id/btn_calendar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Calendar Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_calendar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#F4F5F9"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#4A4A4A" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Header Divider -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@+id/header_layout" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@+id/divider_top"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- Time Filter Toggle (Segmented Control) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardBackgroundColor="#F4F5F9"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Week"
                        android:textColor="#8E8E93"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- Selected State (Month) -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Month"
                            android:textColor="#3100D5"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Year"
                        android:textColor="#8E8E93"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total Spending Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="#3100D5"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_total_spending_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Spending"
                        android:textColor="#E0D7FA"
                        android:textSize="14sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="$3,240.50"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_total_spending_label" />

                    <!-- Percentage Badge -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        app:cardBackgroundColor="#4F26DF"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_amount"
                        app:layout_constraintStart_toEndOf="@+id/tv_amount"
                        app:layout_constraintTop_toTopOf="@+id/tv_amount">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="-5.2%"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Compared to $3,418 last month"
                        android:textColor="#BDB2F0"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_amount" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Spending By Category Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Spending by Category"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Doughnut Chart & Legend Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <!-- Doughnut Chart Mock using overlapping CircularProgressIndicators -->
                <FrameLayout
                    android:id="@+id/chart_container"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <!-- Base (Other) -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:indicatorColor="#E5E5EA"
                        app:trackColor="#00000000"
                        app:indicatorSize="140dp"
                        app:trackThickness="16dp"
                        android:progress="100" />

                    <!-- Green (Food) -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:indicatorColor="#10B981"
                        app:trackColor="#00000000"
                        app:indicatorSize="140dp"
                        app:trackThickness="16dp"
                        android:progress="60" />

                    <!-- Blue (Rent) -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:indicatorColor="#3100D5"
                        app:trackColor="#00000000"
                        app:indicatorSize="140dp"
                        app:trackThickness="16dp"
                        android:progress="45" />

                    <!-- Center Text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="72%"
                            android:textColor="#111111"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL"
                            android:textColor="#8E8E93"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Legend List -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@+id/chart_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <!-- Rent -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="5dp" app:strokeWidth="0dp" android:layout_centerVertical="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@+id/dot1" android:layout_marginStart="10dp" android:text="Rent" android:textColor="#111111" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$1,200" android:textColor="#111111" android:textSize="14sp" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Food -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp" app:cardBackgroundColor="#10B981" app:cardCornerRadius="5dp" app:strokeWidth="0dp" android:layout_centerVertical="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@+id/dot2" android:layout_marginStart="10dp" android:text="Food" android:textColor="#111111" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$840" android:textColor="#111111" android:textSize="14sp" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Transport -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp" app:cardBackgroundColor="#FBBF24" app:cardCornerRadius="5dp" app:strokeWidth="0dp" android:layout_centerVertical="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@+id/dot3" android:layout_marginStart="10dp" android:text="Transport" android:textColor="#111111" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$420" android:textColor="#111111" android:textSize="14sp" android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Other -->
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/dot4" android:layout_width="10dp" android:layout_height="10dp" app:cardBackgroundColor="#E5E5EA" app:cardCornerRadius="5dp" app:strokeWidth="0dp" android:layout_centerVertical="true" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@+id/dot4" android:layout_marginStart="10dp" android:text="Other" android:textColor="#111111" android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="$780" android:textColor="#111111" android:textSize="14sp" android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Weekly Cash Flow Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weekly Cash Flow"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View Details"
                    android:textColor="#3100D5"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!-- Bar Chart Mockup -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:weightSum="6">

                <!-- MON -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="80dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="40dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="MON" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>

                <!-- TUE -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="100dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="50dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="TUE" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>

                <!-- WED -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="90dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="70dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="WED" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>

                <!-- THU -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="120dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="40dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="THU" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>

                <!-- FRI -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="100dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="80dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="FRI" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>

                <!-- SAT -->
                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                    <FrameLayout android:layout_width="48dp" android:layout_height="70dp">
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="match_parent" app:cardBackgroundColor="#EAE6FA" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="20dp" android:layout_gravity="bottom" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="8dp" app:strokeWidth="0dp" app:cardElevation="0dp"/>
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="SAT" android:textSize="10sp" android:textStyle="bold" android:textColor="#B0B0B5"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Top Spending Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="16dp"
                android:text="Top Spending"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Item 1: Apple Store -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FCFCFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icon_apple"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#EAE6FA"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <!-- Using generic lock/bag icon as placeholder -->
                        <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_lock_idle_lock" app:tint="#3100D5" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_apple_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Apple Store"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_apple"
                        app:layout_constraintTop_toTopOf="@+id/icon_apple"
                        app:layout_constraintBottom_toTopOf="@+id/tv_apple_sub" />

                    <TextView
                        android:id="@+id/tv_apple_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Subscription • 12 Oct"
                        android:textColor="#8E8E93"
                        android:textSize="13sp"
                        app:layout_constraintStart_toEndOf="@+id/icon_apple"
                        app:layout_constraintTop_toBottomOf="@+id/tv_apple_title"
                        app:layout_constraintBottom_toBottomOf="@+id/icon_apple" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$19.99"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 2: Whole Foods -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FCFCFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icon_food"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#DDF5E9"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <!-- Fork/knife placeholder -->
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🍴" android:textSize="20sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_food_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Whole Foods"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_food"
                        app:layout_constraintTop_toTopOf="@+id/icon_food"
                        app:layout_constraintBottom_toTopOf="@+id/tv_food_sub" />

                    <TextView
                        android:id="@+id/tv_food_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Groceries • 10 Oct"
                        android:textColor="#8E8E93"
                        android:textSize="13sp"
                        app:layout_constraintStart_toEndOf="@+id/icon_food"
                        app:layout_constraintTop_toBottomOf="@+id/tv_food_title"
                        app:layout_constraintBottom_toBottomOf="@+id/icon_food" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$142.50"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Item 3: Uber Trip -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FCFCFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icon_uber"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardBackgroundColor="#FEF3D6"
                        app:cardCornerRadius="12dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🚗" android:textSize="20sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tv_uber_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Uber Trip"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/icon_uber"
                        app:layout_constraintTop_toTopOf="@+id/icon_uber"
                        app:layout_constraintBottom_toTopOf="@+id/tv_uber_sub" />

                    <TextView
                        android:id="@+id/tv_uber_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Transport • 09 Oct"
                        android:textColor="#8E8E93"
                        android:textSize="13sp"
                        app:layout_constraintStart_toEndOf="@+id/icon_uber"
                        app:layout_constraintTop_toBottomOf="@+id/tv_uber_title"
                        app:layout_constraintBottom_toBottomOf="@+id/icon_uber" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-$24.00"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav Divider Line -->
    <View
        android:id="@+id/bottom_nav_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_mock" />

    <!-- Custom Bottom Navigation Bar Mock (Since standard BottomNavigationView requires external menu.xml) -->
    <LinearLayout
        android:id="@+id/bottom_navigation_mock"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Home -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_preferences" app:tint="#A0A0A5" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Home" android:textColor="#A0A0A5" android:textSize="11sp" />
        </LinearLayout>

        <!-- Analytics (Selected) -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <com.google.android.material.progressindicator.CircularProgressIndicator android:layout_width="24dp" android:layout_height="24dp" app:indicatorColor="#3100D5" app:trackColor="#3100D5" app:indicatorSize="24dp" app:trackThickness="12dp" android:progress="100"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Analytics" android:textColor="#3100D5" android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Wallets -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_gallery" app:tint="#A0A0A5" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Wallets" android:textColor="#A0A0A5" android:textSize="11sp" />
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" app:tint="#A0A0A5" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Settings" android:textColor="#A0A0A5" android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
