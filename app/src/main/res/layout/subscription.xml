<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".SubsDebtActivity">

    <!-- Top App Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Hamburger / Back button used by SubscriptionFragment -->
        <TextView
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textColor="#111111"
            android:textSize="24sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FinSight"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Profile Icon -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_profile"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#F0EFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#3100D5" />
        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Header Divider -->
    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintTop_toBottomOf="@+id/header_layout" />

    <!-- Main Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@+id/divider_top"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_divider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- Summary Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Monthly Subs Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_monthly_subs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💵"
                                android:textColor="#3100D5"
                                android:textSize="14sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Monthly Subs"
                                android:textColor="#4B5563"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="$45.98"
                            android:textColor="#111827"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Total Debt Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_total_debt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FEE2E2"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="2dp"
                                android:text="💳"
                                android:textSize="10sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Total Debt"
                                android:textColor="#4B5563"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="$1,250.00"
                            android:textColor="#111827"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Active Subscriptions Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Subscriptions"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_view_all_subs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="View All"
                    android:clickable="true"
                    android:focusable="true"
                    android:textColor="#3100D5"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <!--
                F3 — RecyclerView populated by SubscriptionAdapter + SubscriptionViewHolder.
                The three static subscription items (Netflix, Spotify, Adobe) that were
                here have been replaced by this dynamic RecyclerView.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_subscriptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:nestedScrollingEnabled="false" />

            <!-- Sub 1: Netflix -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/icon_netflix"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#0E0E0E"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <!-- Custom 'N' Logo -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="N" android:textColor="#E50914" android:textSize="24sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_netflix_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Netflix"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/icon_netflix"
                    app:layout_constraintTop_toTopOf="@+id/icon_netflix"
                    app:layout_constraintBottom_toTopOf="@+id/tv_netflix_sub" />

                <TextView
                    android:id="@+id/tv_netflix_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Next due: Oct 12"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/icon_netflix"
                    app:layout_constraintTop_toBottomOf="@+id/tv_netflix_title"
                    app:layout_constraintBottom_toBottomOf="@+id/icon_netflix" />

                <TextView
                    android:id="@+id/tv_netflix_amt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$15.99"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tv_netflix_title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_netflix_sub" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Sub 2: Spotify -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/icon_spotify"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#216D4B"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <!-- Green circular mock icon -->
                    <com.google.android.material.card.MaterialCardView android:layout_width="28dp" android:layout_height="28dp" app:cardBackgroundColor="#1DB954" app:cardCornerRadius="14dp" app:strokeWidth="0dp" android:layout_gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="≡" android:textColor="#111111" android:textSize="16sp" android:textStyle="bold" android:rotation="90"/>
                    </com.google.android.material.card.MaterialCardView>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_spotify_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Spotify Premium"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/icon_spotify"
                    app:layout_constraintTop_toTopOf="@+id/icon_spotify"
                    app:layout_constraintBottom_toTopOf="@+id/tv_spotify_sub" />

                <TextView
                    android:id="@+id/tv_spotify_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Next due: Oct 18"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/icon_spotify"
                    app:layout_constraintTop_toBottomOf="@+id/tv_spotify_title"
                    app:layout_constraintBottom_toBottomOf="@+id/icon_spotify" />

                <TextView
                    android:id="@+id/tv_spotify_amt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$9.99"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tv_spotify_title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_spotify_sub" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Sub 3: Adobe -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/icon_adobe"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="#212121"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">
                    <!-- Text based cloud icon -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="☁️" android:textColor="#FF0000" android:textSize="22sp" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tv_adobe_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Adobe Creative Cloud"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toEndOf="@+id/icon_adobe"
                    app:layout_constraintTop_toTopOf="@+id/icon_adobe"
                    app:layout_constraintBottom_toTopOf="@+id/tv_adobe_sub" />

                <TextView
                    android:id="@+id/tv_adobe_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Next due: Oct 22"
                    android:textColor="#6B7280"
                    android:textSize="13sp"
                    app:layout_constraintStart_toEndOf="@+id/icon_adobe"
                    app:layout_constraintTop_toBottomOf="@+id/tv_adobe_title"
                    app:layout_constraintBottom_toBottomOf="@+id/icon_adobe" />

                <TextView
                    android:id="@+id/tv_adobe_amt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$19.99"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tv_adobe_title" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MONTHLY"
                    android:textColor="#9CA3AF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@+id/tv_adobe_sub" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Debt & IOUs Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Debt &amp; IOUs"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_centerVertical="true" />

                <!-- Pill Add Button — btn_add_subscription used by SubscriptionFragment (F4) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_add_subscription"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#3100D5"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:paddingHorizontal="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginEnd="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add New" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <!-- Debt Item 1: Owe (Red) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_debt_owe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#FFFAFA"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#FEE2E2"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- Red Arrow Avatar -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_owe"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="#FEE2E2"
                            app:cardCornerRadius="22dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="↘" android:textColor="#DC2626" android:textSize="20sp" android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_owe_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="You owe Mike Ross"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@+id/icon_owe"
                            app:layout_constraintTop_toTopOf="@+id/icon_owe"
                            app:layout_constraintBottom_toTopOf="@+id/tv_owe_sub" />

                        <TextView
                            android:id="@+id/tv_owe_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="For: Dinner last night"
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            app:layout_constraintStart_toEndOf="@+id/icon_owe"
                            app:layout_constraintTop_toBottomOf="@+id/tv_owe_title"
                            app:layout_constraintBottom_toBottomOf="@+id/icon_owe" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$42.00"
                            android:textColor="#DC2626"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Reminder Strip -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#FEE2E2"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/ic_popup_reminder"
                                app:tint="#DC2626" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Reminder: Pay by Friday, 8:00 PM"
                                android:textColor="#374151"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Debt Item 2: Owed To (Green) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_debt_owed_to"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#F4FDF8"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#A7F3D0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <!-- Green Arrow Avatar -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_owed"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="#D1FAE5"
                            app:cardCornerRadius="22dp"
                            app:strokeWidth="0dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="↗" android:textColor="#059669" android:textSize="20sp" android:textStyle="bold" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_owed_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Sarah owes you"
                            android:textColor="#111111"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toEndOf="@+id/icon_owed"
                            app:layout_constraintTop_toTopOf="@+id/icon_owed"
                            app:layout_constraintBottom_toTopOf="@+id/tv_owed_sub" />

                        <TextView
                            android:id="@+id/tv_owed_sub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="For: Concert Tickets"
                            android:textColor="#6B7280"
                            android:textSize="13sp"
                            app:layout_constraintStart_toEndOf="@+id/icon_owed"
                            app:layout_constraintTop_toBottomOf="@+id/tv_owed_title"
                            app:layout_constraintBottom_toBottomOf="@+id/icon_owed" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$120.00"
                            android:textColor="#059669"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Status Strip -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#A7F3D0"
                        app:strokeWidth="1dp">
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="10dp">

                            <ImageView
                                android:id="@+id/ic_clock"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#059669"
                                android:layout_centerVertical="true" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@+id/ic_clock"
                                android:layout_marginStart="8dp"
                                android:text="Requested 2 days ago"
                                android:textColor="#374151"
                                android:textSize="12sp"
                                android:layout_centerVertical="true" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="RESEND"
                                android:textColor="#059669"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:layout_centerVertical="true" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav Divider Line -->
    <View
        android:id="@+id/bottom_nav_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        app:layout_constraintBottom_toTopOf="@+id/bottom_navigation_mock" />

    <!-- Custom Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_navigation_mock"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Overview -->
        <LinearLayout android:id="@+id/mock_nav_overview" android:clickable="true" android:focusable="true" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⊞" android:textColor="#A0A0A5" android:textSize="22sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="OVERVIEW" android:textColor="#A0A0A5" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- SUBS (Active) -->
        <LinearLayout android:id="@+id/mock_nav_subs" android:clickable="true" android:focusable="true" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <!-- Mocking a card/sub icon -->
            <com.google.android.material.card.MaterialCardView android:layout_width="20dp" android:layout_height="14dp" app:cardBackgroundColor="#3100D5" app:cardCornerRadius="2dp" app:strokeWidth="0dp" android:layout_marginBottom="4dp" android:layout_marginTop="4dp">
                <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#FFFFFF" android:layout_marginTop="3dp"/>
            </com.google.android.material.card.MaterialCardView>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="SUBS" android:textColor="#3100D5" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- DEBT -->
        <LinearLayout android:id="@+id/mock_nav_debt" android:clickable="true" android:focusable="true" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🏛️" android:textSize="18sp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="DEBT" android:textColor="#A0A0A5" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- SETTINGS -->
        <LinearLayout android:id="@+id/mock_nav_settings_sub" android:clickable="true" android:focusable="true" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_preferences" app:tint="#A0A0A5" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="SETTINGS" android:textColor="#A0A0A5" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.05" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>